# Printer Hardware (confirmed via lsusb on Pi — Jolimark thermal printer)
PRINTER_VENDOR_ID=0x1ba0
PRINTER_PRODUCT_ID=0x220a

# Service Configuration
PORT=9000

# Paths (used in Docker)
DATA_DIR=/app/data

# GitHub username — used for GHCR image pull in docker-compose.yml
# Set this to your GitHub username (e.g. conorloveis) before running docker compose on the Pi
GITHUB_USER=your-github-username
